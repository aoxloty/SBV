# Discord Application Credentials
# Lấy từ https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_BOT_TOKEN=your_bot_token_here

# URL công khai của server bạn (dùng ngrok khi test local)
# Ví dụ: https://yourapp.railway.app
BASE_URL=https://yourapp.com

# Secret để ký session (đặt chuỗi ngẫu nhiên dài)
SESSION_SECRET=change_this_to_a_random_secret_string

# Port server lắng nghe
PORT=3000
